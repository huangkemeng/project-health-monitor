# Database Configuration (MySQL 8.4)
MYSQL_HOST=your-mysql-host.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_DATABASE=health_monitor
MYSQL_USER=your_username
MYSQL_PASSWORD=your_secure_password
MYSQL_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# Cron Job Secret
CRON_SECRET=your-cron-secret-key-for-verification

# Frontend API URL
NEXT_PUBLIC_API_URL=https://your-domain.vercel.app/api

# Node Environment
NODE_ENV=production
